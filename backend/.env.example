# o-229 Environment Variables — EXAMPLE TEMPLATE
# ─────────────────────────────────────────────────────
# Copy this file to .env and fill in your actual values.
# NEVER commit real credentials to version control.

APP_NAME="o-229 Education"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_DOMAIN=o-229.com

# ─── Logging ─────────────────────────────────────────
LOG_CHANNEL=daily
LOG_LEVEL=warning

# ─── Database (PostgreSQL) ───────────────────────────
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=o229_education
DB_USERNAME=postgres
DB_PASSWORD=your_secure_password_here

# ─── Redis ───────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null

# ─── Cache / Session / Queue ────────────────────────
CACHE_STORE=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis
SESSION_LIFETIME=120

# ─── Broadcasting (Reverb) ──────────────────────────
BROADCAST_CONNECTION=reverb
REVERB_APP_ID=o229-education
REVERB_APP_KEY=your_reverb_key
REVERB_APP_SECRET=your_reverb_secret
REVERB_HOST=reverb
REVERB_PORT=8080
REVERB_SCHEME=http

# ─── Filesystem ─────────────────────────────────────
FILESYSTEM_DISK=local

# ─── Mail ────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@o-229.com"
MAIL_FROM_NAME="${APP_NAME}"

# ─── Cloudflare ─────────────────────────────────────
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_ACCOUNT_ID=

# ─── Sanctum ────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,localhost:5173,*.o-229.com

# ─── O-229 WATCHDOG & MONITORING ────────────────────
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=1.0
WATCHDOG_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=