# o-229 Environment Variables — EXAMPLE TEMPLATE
# ─────────────────────────────────────────────────────
# Copy this file to .env and fill in your actual values.
# NEVER commit real credentials to version control.

APP_NAME="o-229 Education"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_DOMAIN=o-229.com

# ─── Logging ─────────────────────────────────────────
LOG_CHANNEL=daily
LOG_LEVEL=warning

# ─── Database (PostgreSQL) ───────────────────────────
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=o229_education
DB_USERNAME=postgres
DB_PASSWORD=your_secure_password_here

# ─── Redis ───────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null

# ─── Cache / Session / Queue ────────────────────────
CACHE_STORE=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis
SESSION_LIFETIME=120

# ─── Broadcasting (Reverb) ──────────────────────────
BROADCAST_CONNECTION=reverb
REVERB_APP_ID=o229-education
REVERB_APP_KEY=your_reverb_key
REVERB_APP_SECRET=your_reverb_secret
REVERB_HOST=reverb
REVERB_PORT=8080
REVERB_SCHEME=http

# ─── Filesystem ─────────────────────────────────────
FILESYSTEM_DISK=local

# ─── SMS SERVICES (TWILIO) ──────────────────────────
TWILIO_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# ─── EMAIL SERVICES (MAILGUN/RESEND) ───────────────
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@o-229.com"
MAIL_FROM_NAME="${APP_NAME}"

RESEND_KEY=
MAILGUN_DOMAIN=
MAILGUN_SECRET=

# ─── Cloudflare ─────────────────────────────────────
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_ACCOUNT_ID=

# ─── Sanctum ────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,localhost:5173,*.o-229.com

# ─── O-229 WATCHDOG & MONITORING ────────────────────
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=1.0
WATCHDOG_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Payment Gateway (CinetPay / FedaPay) ──────────
# ⚠️ REQUIRED: Set webhook_secret to validate incoming webhooks
PAYMENT_GATEWAY_PROVIDER=cinetpay
PAYMENT_GATEWAY_API_KEY=
PAYMENT_GATEWAY_SITE_ID=
PAYMENT_GATEWAY_WEBHOOK_SECRET=your_webhook_hmac_secret_here

# ─── Google Maps ────────────────────────────────────
GOOGLE_MAPS_API_KEY=

# ─── Backup Encryption ──────────────────────────────
BACKUP_ARCHIVE_PASSWORD=your_backup_encryption_password_here

# ─── Cloudflare R2 / AWS S3 (Backups Externes) ──────
# Utilisé par Laravel-Backup (Disque 's3')
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=auto
AWS_BUCKET=o229-backups-bucket
AWS_USE_PATH_STYLE_ENDPOINT=false
# Ex pour Cloudflare R2: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
AWS_ENDPOINT=