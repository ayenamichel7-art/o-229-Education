# ─── o-229 Docker Environment Variables ─────────────────
# This file is used by docker-compose.yml
# Copy this to .env.docker and fill in your values
# NEVER commit the actual .env.docker file!

# ─── Database ────────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=o229_education
DB_USERNAME=postgres
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ─── Redis ───────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ─── Cache / Session / Queue ────────────────────────────
CACHE_DRIVER=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis

# ─── Broadcasting ───────────────────────────────────────
BROADCAST_CONNECTION=reverb

# ─── MinIO (S3 Compatible) ──────────────────────────────
AWS_ACCESS_KEY_ID=admin
AWS_SECRET_ACCESS_KEY=CHANGE_ME_MINIO_SECRET
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=o229-backups
AWS_ENDPOINT=http://minio:9000
AWS_USE_PATH_STYLE_ENDPOINT=true

# ─── MinIO Root Credentials ─────────────────────────────
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_SECRET
